# ─── Local development ───────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#
# The frontend calls the backend directly from the browser.
# CORS is open (*) on the HF Space FastAPI, so no proxy is needed.

# URL of the FastAPI backend (HF Space or local uvicorn)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:7860

# ─── Production (Vercel) ─────────────────────────────────────────────────────
# In Vercel → Project Settings → Environment Variables, set:
#
#   NEXT_PUBLIC_BACKEND_URL = https://tadashiroo-rag-pt-backend.hf.space
